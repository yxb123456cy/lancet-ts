{
  "name": "@qy/lancet-ts-core",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rslib build",
    "check": "biome check --write",
    "lint": "biome check",
    "check-types": "tsc --noEmit",
    "dev": "rslib build --watch",
    "format": "biome format --write",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "gen:docs": "typedoc",
    "build:rsdoctor": "cross-env RSDOCTOR=true rslib build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@rsdoctor/rspack-plugin": "^1.5.3",
    "@rslib/core": "^0.19.6",
    "@rstest/adapter-rslib": "^0.2.0",
    "@rstest/core": "^0.8.5",
    "@types/node": "^24.10.13",
    "cross-env": "^10.1.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "description": "一个基于 Rspack 技术栈构建的现代化 TypeScript 工具函数库，旨在提供高性能、类型安全且易于维护的常用工具函数。",
  "keywords": [
    "rspack",
    "typescript",
    "utils",
    "lancet"
  ],
  "author": "yxb123456cy <2186256471@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yxb123456cy/lancet-ts.git"
  },
  "homepage": "https://lancet-ts.pages.dev/guide/index.html",
  "bugs": {
    "url": "https://github.com/yxb123456cy/lancet-ts/issues"
  }
}
